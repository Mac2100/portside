{
  "name": "portside",
  "version": "1.8.1",
  "description": "Native Mac Docker manager for QNAP Container Station",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.portside.app",
    "productName": "Portside",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "allowScripts": {
    "electron@28.3.3": true
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "js-yaml": "^4.1.0"
  }
}
